---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Drafts are excluded from production builds but visible while developing,
// so a post can be committed and reviewed before it is published.
const posts = (await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout title="Blog" description="Notes on building and shipping Olmbox.">
  <div class="container-page py-14">
    <h1 class="text-4xl font-extrabold tracking-tight">Blog</h1>
    <p class="mt-3 max-w-2xl text-lg" style="color: var(--text-muted);">
      Release notes and notes on how the plugin is built.
    </p>

    {
      posts.length === 0 && (
        <p class="mt-10" style="color: var(--text-muted);">
          No posts published yet.
        </p>
      )
    }

    <div class="mt-10 space-y-5">
      {
        posts.map((post) => (
          <a href={`/blog/${post.id}`} class="card block p-6 no-underline transition-colors hover:border-[var(--color-accent)]">
            <div class="flex flex-wrap items-center gap-3 text-xs" style="color: var(--text-muted);">
              <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
              {post.data.draft && (
                <span
                  class="rounded-full px-2 py-0.5 font-semibold"
                  style="background: rgba(245,197,24,0.18); color: #9a7b00;"
                >
                  Draft
                </span>
              )}
            </div>
            <h2 class="mt-2 text-xl font-semibold">{post.data.title}</h2>
            <p class="mt-2 text-sm leading-relaxed" style="color: var(--text-muted);">
              {post.data.description}
            </p>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
