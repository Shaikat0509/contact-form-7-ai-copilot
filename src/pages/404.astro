---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="That page does not exist.">
  <div class="container-page flex min-h-[60vh] flex-col items-center justify-center text-center">
    <p class="text-6xl font-extrabold tracking-tight" style="color: var(--color-accent);">404</p>
    <h1 class="mt-4 text-2xl font-bold">That page does not exist</h1>
    <p class="mt-3 max-w-md" style="color: var(--text-muted);">
      The link may be out of date. The documentation index is the best place to pick
      things back up.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn btn-primary">Home</a>
      <a href="/docs" class="btn btn-ghost">Documentation</a>
    </div>
  </div>
</BaseLayout>
