# Dev tooling only — the plugin itself has no runtime dependencies.
# composer.lock and package-lock.json are committed; the installed
# packages/binaries themselves are not.
/vendor/
/node_modules/

# OS / editor
.DS_Store
.idea/
.vscode/

# Claude Code local session config — not part of the plugin.
.claude/

# Build/test artifacts
*.zip
*.log

# WordPress core PHPUnit harness, fetched on demand by
# docker/install-wp-tests.sh. Large, version-pinned, and reproducible.
/docker/.wp-tests-lib/

# Built distribution zips.
/dist/
